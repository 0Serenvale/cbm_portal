<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_clinic_workstation_tree" model="ir.ui.view">
        <field name="name">clinic.workstation.tree</field>
        <field name="model">clinic.workstation</field>
        <field name="arch" type="xml">
            <tree string="Workstations">
                <field name="name"/>
                <field name="ip_address"/>
                <field name="location_name"/>
                <field name="assigned_employee_id"/>
                <field name="assigned_user_id" optional="hide"/>
                <field name="is_configured" widget="boolean_toggle"/>
                <field name="last_seen"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_clinic_workstation_form" model="ir.ui.view">
        <field name="name">clinic.workstation.form</field>
        <field name="model">clinic.workstation</field>
        <field name="arch" type="xml">
            <form string="Workstation">
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger"
                            attrs="{'invisible': [('active', '=', True)]}"/>
                    <div class="oe_button_box" name="button_box">
                        <button name="toggle_active" type="object"
                                class="oe_stat_button" icon="fa-archive">
                            <field name="active" widget="boolean_button"
                                   options='{"terminology": "archive"}'/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Post name..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="ip_address"/>
                            <field name="location_name" placeholder="e.g. Floor 5, Reception"/>
                            <field name="is_configured"/>
                        </group>
                        <group>
                            <field name="assigned_employee_id"/>
                            <field name="assigned_user_id"/>
                            <field name="last_seen" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="notes" placeholder="Admin notes..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_clinic_workstation_search" model="ir.ui.view">
        <field name="name">clinic.workstation.search</field>
        <field name="model">clinic.workstation</field>
        <field name="arch" type="xml">
            <search string="Search Workstations">
                <field name="name"/>
                <field name="ip_address"/>
                <field name="location_name"/>
                <field name="assigned_employee_id"/>
                <separator/>
                <filter name="unconfigured" string="Unconfigured"
                        domain="[('is_configured', '=', False)]"/>
                <filter name="configured" string="Configured"
                        domain="[('is_configured', '=', True)]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="groupby_location" string="Location"
                            context="{'group_by': 'location_name'}"/>
                    <filter name="groupby_configured" string="Configured"
                            context="{'group_by': 'is_configured'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_clinic_workstation" model="ir.actions.act_window">
        <field name="name">Workstations</field>
        <field name="res_model">clinic.workstation</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{'search_default_unconfigured': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No workstations registered yet
            </p>
            <p>
                Workstations are auto-created when users access the kiosk from new IP addresses.
                Configure them to assign physical locations and employees.
            </p>
        </field>
    </record>

    <!-- Menu Item - under Kiosk Admin root -->
    <menuitem id="menu_clinic_workstation"
              name="Workstations"
              parent="menu_cbm_kiosk_admin_root"
              action="action_clinic_workstation"
              sequence="20"
              groups="base.group_system"/>
</odoo>
