<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_drug_sync_wizard_form" model="ir.ui.view">
        <field name="name">drug.sync.wizard.form</field>
        <field name="model">drug.sync.wizard</field>
        <field name="arch" type="xml">
            <form string="Drug Registration">
                <group>
                    <field name="product_tmpl_id" string="Product" readonly="1"/>
                    <field name="drug_name" string="Prescribing Name"/>
                </group>
                <group string="Active Ingredient (DCI)">
                    <field name="concept_id" string="Active Ingredient"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                </group>
                <group string="Pharmaceutical Details">
                    <field name="dosage_form_id"
                           options="{'no_create': True, 'no_create_edit': True}"/>
                    <field name="strength" placeholder="e.g. 500 mg, 10 mg/ml"/>
                </group>
                <footer>
                    <button name="action_confirm_sync" string="Register Drug"
                            type="object" class="btn-primary" icon="fa-check"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
