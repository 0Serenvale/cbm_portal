<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- Inventory Warning Banner -->
    <t t-name="clinic_staff_portal.InventoryBanner" owl="1">
        <div t-if="state.show" t-attf-class="{{ getBannerClass() }}" class="inventory-banner-container">
            <div class="inventory-banner-content">

                <!-- Icon -->
                <div class="inventory-banner-icon">
                    <svg class="icon-warning" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3.05h16.94a2 2 0 0 0 1.71-3.05L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                        <line x1="12" y1="9" x2="12" y2="13"/>
                        <line x1="12" y1="17" x2="12.01" y2="17"/>
                    </svg>
                </div>

                <!-- Urgency label pill -->
                <span class="inventory-banner-label" t-esc="getUrgencyLabel()"/>

                <!-- Message -->
                <div class="inventory-banner-message">
                    <p class="inventory-banner-text" t-esc="getAnnouncementText()"/>
                </div>

                <!-- Dismiss -->
                <button type="button" class="inventory-banner-close" t-on-click="onDismissBanner" title="Fermer">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="18" y1="6" x2="6" y2="18"/>
                        <line x1="6" y1="6" x2="18" y2="18"/>
                    </svg>
                </button>

            </div>
        </div>
    </t>

</templates>
