<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clinic_staff_portal.InventoryCount" owl="1">
        <!-- Header -->
        <div class="cbm_page_header">
            <button class="cbm_back_btn" t-on-click="goHome" title="Retour à l'accueil">
                <span class="cbm_icon_arrow_left"/>Retour
            </button>
            <div class="cbm_page_title">
                <h2>Comptage d'Inventaire</h2>
                <t t-if="state.sessionFound">
                    <span class="cbm_page_subtitle" t-esc="state.teamName + ' • ' + state.locationName"/>
                </t>
            </div>
            <button t-if="state.sessionFound" class="cbm_print_btn" t-on-click="printTeamPDF" title="Imprimer le rapport">
                <span class="cbm_icon_printer"/>
            </button>
            <button class="cbm_close_btn" t-on-click="goHome">
                <span class="cbm_icon_x"/>
            </button>
        </div>

        <!-- Main Content -->
        <div class="cbm_page_body">
            <div class="cbm_page_content">
                <!-- Loading State -->
                <div t-if="state.sessionLoading" class="cbm_inventory_loading">
                    <span class="spinner-border spinner-border-sm me-2"/>
                    Chargement de la session...
                </div>

                <!-- No Session State -->
                <div t-elif="not state.sessionFound" class="cbm_inventory_no_session">
                    <div class="cbm_empty_icon">
                        <span class="cbm_icon_inbox"/>
                    </div>
                    <h3 class="cbm_empty_title">Aucune session active</h3>
                    <p class="cbm_empty_message">
                        Vous n'êtes pas assigné à une session d'inventaire actuellement.
                        Contactez votre responsable pour commencer le comptage.
                    </p>
                    <button class="cbm_btn cbm_btn_primary" t-on-click="goHome">
                        <span class="cbm_icon_home me-2"/>
                        Retour à l'accueil
                    </button>
                </div>

                <!-- Counting Interface -->
                <div t-else="" class="cbm_inventory_container">
                    <!-- Barcode Scanner Input Section -->
                    <div class="cbm_inventory_search_section">
                        <div class="cbm_search_box">
                            <div class="cbm_search_input_wrapper">
                                <span class="cbm_icon_barcode"/>
                                <input type="text"
                                       class="cbm_barcode_input"
                                       placeholder="Scanner code-barres ou taper (Entrée)..."
                                       t-ref="barcodeInput"
                                       t-on-keydown="onBarcodeInput"
                                       t-on-input="onBarcodeInputChange"
                                       autocomplete="off"
                                       inputmode="none"/>
                                <span t-if="state.barcodeLoading" class="spinner-border spinner-border-sm"/>
                            </div>
                            <button class="cbm_camera_btn" t-on-click="openCamera" title="Ouvrir la caméra" t-att-disabled="state.barcodeLoading">
                                <span class="cbm_icon_camera"/>
                            </button>
                        </div>
                    </div>

                    <!-- Camera Modal -->
                    <div t-if="state.cameraOpen" class="cbm_camera_modal">
                        <div class="cbm_camera_backdrop" t-on-click="closeCamera"/>
                        <div class="cbm_camera_container">
                            <div class="cbm_camera_header">
                                <h3>Scanner un code-barres</h3>
                                <button class="cbm_camera_close" t-on-click="closeCamera">
                                    <span class="cbm_icon_x"/>
                                </button>
                            </div>
                            <div class="cbm_camera_body">
                                <video t-ref="cameraVideo" class="cbm_camera_video" playsinline="true" autoplay="true" muted="true"/>
                                <div class="cbm_camera_hint">
                                    <p>Pointez la caméra vers un code-barres</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Confirmation Modal -->
                    <div t-if="state.deleteConfirmLineId" class="cbm_inventory_form_modal">
                        <div class="cbm_form_backdrop" t-on-click="cancelDelete"/>
                        <div class="cbm_form_card cbm_confirm_card">
                            <div class="cbm_confirm_icon">
                                <span class="cbm_icon_trash"/>
                            </div>
                            <h3>Supprimer cette ligne ?</h3>
                            <p>Cette action ne peut pas être annulée.</p>
                            <div class="cbm_form_actions">
                                <button class="cbm_btn cbm_btn_secondary" t-on-click="cancelDelete">Annuler</button>
                                <button class="cbm_btn cbm_btn_danger" t-on-click="deleteLine">Supprimer</button>
                            </div>
                        </div>
                    </div>

                    <!-- Lines Table -->
                    <div class="cbm_inventory_lines_section">
                        <h3 class="cbm_lines_title">Produits comptés (<t t-esc="state.lines.length"/>)</h3>

                        <!-- Table Search Bar -->
                        <t t-if="state.lines.length > 0">
                            <div class="cbm_inventory_table_controls">
                                <div class="cbm_table_search_wrapper">
                                    <span class="cbm_icon_search"/>
                                    <input type="text"
                                           class="cbm_table_search_input"
                                           placeholder="Chercher produit, lot, code-barres..."
                                           t-model="state.tableSearchQuery"
                                           t-on-input="onTableSearchChange"
                                           autocomplete="off"/>
                                    <t t-if="state.tableSearchQuery">
                                        <button class="cbm_table_clear_search" t-on-click="clearTableSearch" title="Effacer">
                                            <span class="cbm_icon_x"/>
                                        </button>
                                    </t>
                                </div>
                            </div>
                        </t>

                        <div t-if="state.linesLoading" class="cbm_lines_loading">
                            <span class="spinner-border spinner-border-sm me-2"/>
                            Chargement des lignes...
                        </div>

                        <div t-elif="state.lines.length === 0" class="cbm_lines_empty">
                            <span class="cbm_icon_inbox"/>
                            <p>Aucun produit comptabilisé pour le moment.</p>
                            <p class="cbm_lines_empty_hint">Scannez un code-barres ci-dessus pour commencer.</p>
                        </div>

                        <t t-set="filteredLines" t-value="getFilteredLines()"/>

                        <div t-if="state.tableSearchQuery and filteredLines.length === 0" class="cbm_lines_empty">
                            <span class="cbm_icon_inbox"/>
                            <p>Aucun résultat pour "<t t-esc="state.tableSearchQuery"/>"</p>
                            <p class="cbm_lines_empty_hint">Essayez un autre terme de recherche.</p>
                        </div>

                        <div t-elif="filteredLines.length > 0" class="cbm_lines_table">
                            <table class="cbm_table">
                                <thead>
                                    <tr>
                                        <th class="cbm_col_product">Produit</th>
                                        <th class="cbm_col_lot">Lot</th>
                                        <th class="cbm_col_expiry">Expiry</th>
                                        <th class="cbm_col_qty">Quantité</th>
                                        <th class="cbm_col_uom">UoM</th>
                                        <th class="cbm_col_actions">Supprimer</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="filteredLines" t-as="line" t-key="line.id">
                                        <tr class="cbm_table_row">
                                            <td class="cbm_col_product" t-esc="line.product_name"/>
                                            <td class="cbm_col_lot" t-esc="line.lot_name or '-'"/>
                                            <td class="cbm_col_expiry">
                                                <t t-if="line.expiry_date" t-esc="line.expiry_date"/>
                                                <t t-else="">-</t>
                                            </td>
                                            <!-- Inline Qty Field -->
                                            <td class="cbm_col_qty">
                                                <t t-if="state.editingLineId === line.id">
                                                    <!-- Edit mode: input field -->
                                                    <input type="number"
                                                           class="cbm_qty_inline_input"
                                                           t-att-data-line-id="line.id"
                                                           t-model="state.editingLineQty"
                                                           t-on-change="onQtyChange"
                                                           t-on-blur="() => this.onQtyBlur(line.id)"
                                                           step="0.01"
                                                           min="0"
                                                           placeholder="0.00"
                                                           t-att-disabled="state.savingLineId === line.id"/>
                                                    <span t-if="state.savingLineId === line.id" class="cbm_qty_saving_spinner">
                                                        <span class="spinner-border spinner-border-sm"/>
                                                    </span>
                                                </t>
                                                <t t-else="">
                                                    <!-- Display mode: click to edit -->
                                                    <span class="cbm_qty_display" t-on-click="() => this.onQtyStartEdit(line.id, line.qty_counted)">
                                                        <t t-esc="line.qty_counted.toFixed(2)"/>
                                                    </span>
                                                </t>
                                            </td>
                                            <td class="cbm_col_uom" t-esc="line.uom_name"/>
                                            <td class="cbm_col_actions">
                                                <button class="cbm_action_btn cbm_action_delete"
                                                        t-on-click="() => this.confirmDelete(line.id)"
                                                        title="Supprimer cette ligne">
                                                    <span class="cbm_icon_trash"/>
                                                    Supprimer
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="cbm_page_footer">
            <div class="cbm_footer_actions">
                <button class="cbm_btn cbm_btn_secondary" t-on-click="goHome">
                    <span class="cbm_icon_x me-2"/>
                    Quitter
                </button>
            </div>
        </div>
    </t>

</templates>
