<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clinic_staff_portal.InventoryCount" owl="1">
        <!-- Header -->
        <div class="cbm_page_header">
            <button class="cbm_back_btn" t-on-click="goHome" title="Retour à l'accueil">
                <span class="cbm_icon_arrow_left"/>Retour
            </button>
            <div class="cbm_page_title">
                <h2>Comptage d'Inventaire</h2>
                <t t-if="state.sessionFound">
                    <span class="cbm_page_subtitle" t-esc="state.teamName + ' • ' + state.locationName"/>
                </t>
            </div>
            <button t-if="state.sessionFound" class="cbm_print_btn" t-on-click="printTeamPDF" title="Imprimer le rapport">
                <span class="cbm_icon_printer"/>
            </button>
            <button class="cbm_close_btn" t-on-click="goHome">
                <span class="cbm_icon_x"/>
            </button>
        </div>

        <!-- Main Content -->
        <div class="cbm_page_body">
            <div class="cbm_page_content">
                <!-- Loading State -->
                <div t-if="state.sessionLoading" class="cbm_inventory_loading">
                    <span class="spinner-border spinner-border-sm me-2"/>
                    Chargement de la session...
                </div>

                <!-- No Session State -->
                <div t-elif="not state.sessionFound" class="cbm_inventory_no_session">
                    <div class="cbm_empty_icon">
                        <span class="cbm_icon_inbox"/>
                    </div>
                    <h3 class="cbm_empty_title">Aucune session active</h3>
                    <p class="cbm_empty_message">
                        Vous n'êtes pas assigné à une session d'inventaire actuellement.
                        Contactez votre responsable pour commencer le comptage.
                    </p>
                    <button class="cbm_btn cbm_btn_primary" t-on-click="goHome">
                        <span class="cbm_icon_home me-2"/>
                        Retour à l'accueil
                    </button>
                </div>

                <!-- Counting Interface -->
                <div t-else="" class="cbm_inventory_container">
                    <!-- Search/Barcode Input Section -->
                    <div class="cbm_inventory_search_section">
                        <div class="cbm_search_box">
                            <div class="cbm_search_input_wrapper">
                                <span class="cbm_icon_barcode"/>
                                <input type="text"
                                       class="cbm_barcode_input"
                                       placeholder="Scanner un code-barres (Entrée)..."
                                       t-ref="barcodeInput"
                                       t-on-keydown="onBarcodeInput"
                                       autocomplete="off"/>
                            </div>
                            <div class="cbm_search_divider">OU</div>
                            <div class="cbm_search_input_wrapper cbm_product_search">
                                <span class="cbm_icon_search"/>
                                <input type="text"
                                       class="cbm_search_input"
                                       placeholder="Rechercher un produit..."
                                       t-model="state.searchQuery"
                                       t-on-input="onSearchInput"
                                       t-on-keydown="onSearchKeydown"
                                       t-ref="searchInput"
                                       autocomplete="off"/>
                                <span t-if="state.searchLoading" class="spinner-border spinner-border-sm"/>
                            </div>
                        </div>

                        <!-- Search Results Dropdown -->
                        <div t-if="state.searchDropdownOpen and state.searchResults.length > 0" class="cbm_search_dropdown">
                            <div class="cbm_search_results">
                                <t t-foreach="state.searchResults" t-as="result" t-key="result.id">
                                    <div t-att-class="'cbm_search_result_item' + (state.selectedResultIndex === result_index ? ' highlighted' : '')"
                                         t-on-click="() => this.selectProduct(result)">
                                        <div class="cbm_result_info">
                                            <span class="cbm_result_name" t-esc="result.name"/>
                                            <span class="cbm_result_barcode" t-if="result.barcode" t-esc="'Code: ' + result.barcode"/>
                                        </div>
                                        <div class="cbm_result_meta">
                                            <span class="cbm_result_uom" t-esc="result.uom_name"/>
                                            <span class="cbm_result_qty" t-esc="'Stock: ' + result.qty_system.toFixed(2)"/>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Edit/Add Form (When product selected) -->
                    <div t-if="state.editingLine" class="cbm_inventory_form_modal">
                        <div class="cbm_form_backdrop" t-on-click="cancelEdit"/>
                        <div class="cbm_form_card">
                            <div class="cbm_form_header">
                                <h3>
                                    <t t-if="state.editingLineId">Modifier la ligne</t>
                                    <t t-else="">Ajouter un produit</t>
                                </h3>
                                <button class="cbm_form_close" t-on-click="cancelEdit">
                                    <span class="cbm_icon_x"/>
                                </button>
                            </div>

                            <div class="cbm_form_body">
                                <!-- Product Info (Read-only) -->
                                <div class="cbm_form_field cbm_form_field_readonly">
                                    <label>Produit</label>
                                    <div class="cbm_form_value" t-esc="state.editingLine.product_name"/>
                                </div>

                                <!-- System Qty Reference -->
                                <div class="cbm_form_field cbm_form_field_readonly">
                                    <label>Stock système</label>
                                    <div class="cbm_form_value" t-esc="'${qty} ${uom}'.format(qty=state.editingLine.qty_system.toFixed(2), uom=state.editingLine.uom_name)"/>
                                </div>

                                <!-- Qty Counted Input -->
                                <div class="cbm_form_field">
                                    <label for="qty_counted">Quantité comptée</label>
                                    <div class="cbm_qty_input_group">
                                        <input type="number"
                                               id="qty_counted"
                                               class="cbm_qty_input"
                                               placeholder="0.00"
                                               step="0.01"
                                               min="0"
                                               t-att-value="state.editingLine.qty_counted"
                                               t-on-change="(e) => this.onEditFormInput('qty_counted', e)"
                                               autofocus="true"/>
                                        <span class="cbm_qty_unit" t-esc="state.editingLine.uom_name"/>
                                    </div>
                                </div>

                                <!-- Lot Selection -->
                                <div class="cbm_form_field">
                                    <label for="lot_name">Lot/Série (optionnel)</label>
                                    <input type="text"
                                           id="lot_name"
                                           class="cbm_text_input"
                                           placeholder="Ex: LOT-2026-001"
                                           t-att-value="state.editingLine.lot_name"
                                           t-on-change="(e) => this.onEditFormInput('lot_name', e)"/>
                                </div>

                                <!-- Expiry Date -->
                                <div class="cbm_form_field">
                                    <label for="expiry_date">Date d'expiration (optionnel)</label>
                                    <input type="date"
                                           id="expiry_date"
                                           class="cbm_date_input"
                                           t-att-value="state.editingLine.expiry_date"
                                           t-on-change="(e) => this.onEditFormInput('expiry_date', e)"/>
                                </div>

                                <!-- Notes -->
                                <div class="cbm_form_field">
                                    <label for="note">Remarques (optionnel)</label>
                                    <input type="text"
                                           id="note"
                                           class="cbm_text_input"
                                           placeholder="Notes sur ce comptage..."
                                           t-att-value="state.editingLine.note"
                                           t-on-change="(e) => this.onEditFormInput('note', e)"/>
                                </div>
                            </div>

                            <div class="cbm_form_actions">
                                <button class="cbm_btn cbm_btn_secondary" t-on-click="cancelEdit">Annuler</button>
                                <button class="cbm_btn cbm_btn_primary" t-on-click="saveLine" t-att-disabled="state.savingLine">
                                    <span t-if="state.savingLine" class="spinner-border spinner-border-sm me-2"/>
                                    <t t-if="state.editingLineId">Modifier</t>
                                    <t t-else="">Ajouter</t>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Delete Confirmation Modal -->
                    <div t-if="state.deleteConfirmLineId" class="cbm_inventory_form_modal">
                        <div class="cbm_form_backdrop" t-on-click="cancelDelete"/>
                        <div class="cbm_form_card cbm_confirm_card">
                            <div class="cbm_confirm_icon">
                                <span class="cbm_icon_trash"/>
                            </div>
                            <h3>Supprimer cette ligne ?</h3>
                            <p>Cette action ne peut pas être annulée.</p>
                            <div class="cbm_form_actions">
                                <button class="cbm_btn cbm_btn_secondary" t-on-click="cancelDelete">Annuler</button>
                                <button class="cbm_btn cbm_btn_danger" t-on-click="deleteLine">Supprimer</button>
                            </div>
                        </div>
                    </div>

                    <!-- Lines Table -->
                    <div class="cbm_inventory_lines_section">
                        <h3 class="cbm_lines_title">Produits comptés (<t t-esc="state.lines.length"/>)</h3>

                        <div t-if="state.linesLoading" class="cbm_lines_loading">
                            <span class="spinner-border spinner-border-sm me-2"/>
                            Chargement des lignes...
                        </div>

                        <div t-elif="state.lines.length === 0" class="cbm_lines_empty">
                            <span class="cbm_icon_inbox"/>
                            <p>Aucun produit comptabilisé pour le moment.</p>
                            <p class="cbm_lines_empty_hint">Utilisez la barre de recherche ci-dessus pour commencer.</p>
                        </div>

                        <div t-else="" class="cbm_lines_table">
                            <table class="cbm_table">
                                <thead>
                                    <tr>
                                        <th class="cbm_col_product">Produit</th>
                                        <th class="cbm_col_lot">Lot</th>
                                        <th class="cbm_col_expiry">Expiry</th>
                                        <th class="cbm_col_qty">Qty</th>
                                        <th class="cbm_col_uom">UoM</th>
                                        <th class="cbm_col_actions">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.lines" t-as="line" t-key="line.id">
                                        <tr class="cbm_table_row">
                                            <td class="cbm_col_product" t-esc="line.product_name"/>
                                            <td class="cbm_col_lot" t-esc="line.lot_name or '-'"/>
                                            <td class="cbm_col_expiry">
                                                <t t-if="line.expiry_date" t-esc="line.expiry_date"/>
                                                <t t-else="">-</t>
                                            </td>
                                            <td class="cbm_col_qty" t-esc="line.qty_counted.toFixed(2)"/>
                                            <td class="cbm_col_uom" t-esc="line.uom_name"/>
                                            <td class="cbm_col_actions">
                                                <button class="cbm_action_btn cbm_action_edit"
                                                        t-on-click="() => this.editLine(line)"
                                                        title="Modifier">
                                                    <span class="cbm_icon_pencil"/>
                                                </button>
                                                <button class="cbm_action_btn cbm_action_delete"
                                                        t-on-click="() => this.confirmDelete(line.id)"
                                                        title="Supprimer">
                                                    <span class="cbm_icon_trash"/>
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer -->
        <div class="cbm_page_footer">
            <div class="cbm_footer_actions">
                <button class="cbm_btn cbm_btn_secondary" t-on-click="goHome">
                    <span class="cbm_icon_x me-2"/>
                    Quitter
                </button>
            </div>
        </div>
    </t>

</templates>
