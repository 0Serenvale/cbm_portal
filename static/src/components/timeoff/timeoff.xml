<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="clinic_staff_portal.TimeOffForm" owl="1">
        <!-- Header -->
        <div class="cbm_page_header">
            <button class="cbm_back_btn" t-on-click="goHome" title="Retour à l'accueil">
                <span class="cbm_icon_arrow_left"/>Retour
            </button>
            <div class="cbm_page_title">
                <h2>Demande de Congé</h2>
                <span class="cbm_page_subtitle">Faire une demande d'absence</span>
            </div>
            <button class="cbm_close_btn" t-on-click="goHome">
                <span class="cbm_icon_x"/>
            </button>
        </div>

        <!-- Main Content -->
        <div class="cbm_page_body">
            <div class="cbm_page_content">
                <!-- Loading State -->
                <div t-if="state.timeoffLoading" class="cbm_timeoff_loading">
                    <span class="spinner-border spinner-border-sm me-2"/>
                    Chargement...
                </div>

                <!-- Success State -->
                <div t-elif="state.timeoffSuccess" class="cbm_timeoff_success">
                    <div class="cbm_success_icon">
                        <span class="cbm_icon_check_lg"/>
                    </div>
                    <h3 class="cbm_success_title">Demande envoyée</h3>
                    <p class="cbm_success_message" t-esc="state.timeoffSuccessMessage"/>
                    <div class="cbm_timeoff_success_actions">
                        <button t-if="state.timeoffSuccessLeaveId" class="cbm_btn cbm_btn_secondary" t-on-click="printTimeOff">
                            <span class="cbm_icon_printer me-2"/>
                            Imprimer
                        </button>
                        <button class="cbm_btn_primary" t-on-click="goHome">
                            <span class="cbm_icon_home me-2"/>
                            Retour à l'accueil
                        </button>
                    </div>
                </div>

                <!-- Form -->
                <div t-else="" class="cbm_content_container cbm_timeoff_form">
                    <!-- Employee Selection (visible when there are multiple employees to select) -->
                    <div t-if="state.timeoffEmployees.length > 1" class="cbm_timeoff_section">
                        <label class="cbm_timeoff_label">
                            <span class="cbm_icon_user"/>
                            Employé
                        </label>
                        <div t-att-class="'cbm_employee_dropdown' + (state.timeoffEmployeeDropdownOpen ? ' open' : '')">
                            <div class="cbm_employee_selected" t-on-click="toggleEmployeeDropdown">
                                <div class="cbm_employee_avatar">
                                    <span class="cbm_icon_user"/>
                                </div>
                                <span class="cbm_selected_name" t-esc="getSelectedEmployeeName()"/>
                                <span class="cbm_icon_chevron_down cbm_dropdown_arrow"/>
                            </div>
                            <div t-if="state.timeoffEmployeeDropdownOpen" class="cbm_employee_list">
                                <!-- Search Input -->
                                <div class="cbm_employee_search">
                                    <span class="cbm_icon_search"/>
                                    <input type="text"
                                           class="cbm_employee_search_input"
                                           placeholder="Rechercher un employé..."
                                           t-model="state.timeoffEmployeeSearch"
                                           t-on-input="onEmployeeSearch"
                                           t-on-keydown="onEmployeeSearchKeydown"
                                           t-ref="employeeSearchInput"/>
                                </div>
                                <!-- Employee List -->
                                <div class="cbm_employee_list_items">
                                    <t t-foreach="getFilteredEmployees()" t-as="emp" t-key="emp.id">
                                        <div t-att-class="'cbm_employee_list_item' + (state.timeoffSelectedEmployeeId === emp.id ? ' selected' : '') + (state.timeoffHighlightedEmployeeIndex === emp_index ? ' highlighted' : '')"
                                             t-on-click="() => this.onTimeOffEmployeeSelect(emp.id)"
                                             t-att-data-employee-id="emp.id">
                                            <div class="cbm_employee_avatar">
                                                <span class="cbm_icon_user"/>
                                            </div>
                                            <span class="cbm_item_name" t-esc="emp.name"/>
                                            <span t-if="emp.is_self" class="cbm_self_badge">Moi</span>
                                        </div>
                                    </t>
                                    <div t-if="getFilteredEmployees().length === 0" class="cbm_employee_no_results">
                                        Aucun employé trouvé
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Leave Type Selection -->
                    <div class="cbm_timeoff_section">
                        <label class="cbm_timeoff_label">
                            <span class="cbm_icon_calendar"/>
                            Type de congé
                        </label>
                        <select class="cbm_leave_type_select"
                                t-on-change="onTimeOffLeaveTypeChange"
                                t-att-value="state.timeoffSelectedLeaveTypeId">
                            <option value="">-- Sélectionner un type --</option>
                            <t t-foreach="state.timeoffLeaveTypes" t-as="leaveType" t-key="leaveType.id">
                                <option t-att-value="leaveType.id"
                                        t-att-selected="state.timeoffSelectedLeaveTypeId === leaveType.id"
                                        t-esc="leaveType.name"/>
                            </t>
                        </select>
                    </div>

                    <!-- Date and Duration Row -->
                    <div class="cbm_timeoff_section">
                        <div class="cbm_date_row">
                            <!-- Start Date -->
                            <div class="cbm_date_field">
                                <label class="cbm_timeoff_label">
                                    <span class="cbm_icon_calendar"/>
                                    Date de début
                                </label>
                                <input type="date"
                                       t-ref="dateInput"
                                       class="cbm_date_input"
                                       t-att-value="state.timeoffDateFrom"
                                       t-on-change="onTimeOffDateChange"/>
                            </div>

                            <!-- Number of Days -->
                            <div class="cbm_days_field">
                                <label class="cbm_timeoff_label">
                                    <span class="cbm_icon_clock"/>
                                    Nombre de jours
                                </label>
                                <input type="number"
                                       t-ref="daysInput"
                                       class="cbm_days_input"
                                       min="0.5"
                                       step="0.5"
                                       t-att-value="state.timeoffNumberOfDays"
                                       t-on-change="onTimeOffDaysChange"/>
                            </div>
                        </div>
                    </div>

                    <!-- Reason / Description -->
                    <div class="cbm_timeoff_section">
                        <label class="cbm_timeoff_label">
                            <span class="cbm_icon_chat"/>
                            Motif (optionnel)
                        </label>
                        <textarea class="cbm_reason_textarea"
                                  rows="3"
                                  placeholder="Décrivez le motif de votre demande..."
                                  t-on-input="onTimeOffReasonInput"
                                  t-att-value="state.timeoffReason"/>
                    </div>

                    <!-- Info Panel -->
                    <div class="cbm_timeoff_info" title="Ces informations vous aident à comprendre le processus de demande de congé">
                        <h6 title="Ce qui se passe après l'envoi de votre demande">
                            <span class="cbm_icon_info"/>
                            Que se passe-t-il ensuite ?
                        </h6>
                        <ul>
                            <li>Votre demande sera transmise à votre responsable pour validation</li>
                            <li>Vous recevrez une notification dès que la décision sera prise</li>
                            <li>Consultez la page Suivi pour voir l'état de toutes vos demandes</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <!-- Footer Actions -->
        <div t-if="!state.timeoffLoading &amp;&amp; !state.timeoffSuccess" class="cbm_page_footer">
            <div class="cbm_inv_footer_inner">
                <button class="cbm_inv_footer_cancel" t-on-click="goHome">Annuler</button>
                <button class="cbm_inv_footer_submit"
                        t-on-click="submitTimeOff"
                        t-att-disabled="state.timeoffSubmitting || !isTimeOffFormValid()">
                    <t t-if="state.timeoffSubmitting">
                        <span class="spinner-border spinner-border-sm me-2"/>
                        Envoi en cours...
                    </t>
                    <t t-else="">
                        <span class="cbm_icon_send me-2"/>
                        Envoyer la demande
                    </t>
                </button>
            </div>
        </div>
    </t>


    <t t-name="clinic_staff_portal.TimeoffRequests" owl="1">
        <!-- Header -->
        <div class="cbm_page_header">
            <button class="cbm_back_btn" t-on-click="goHome" title="Retour à l'accueil">
                <span class="cbm_icon_arrow_left"/>Retour
            </button>
            <div class="cbm_page_title">
                <h2>Demandes de Congé</h2>
                <span class="cbm_page_subtitle">Gérer les demandes de l'équipe</span>
            </div>
            <button class="cbm_close_btn" t-on-click="goHome">
                <span class="cbm_icon_x"/>
            </button>
        </div>

        <!-- Main Content -->
        <div class="cbm_page_body">
            <div class="cbm_page_content">

                <!-- Loading -->
                <div t-if="state.loading" class="cbm_timeoff_loading">
                    <span class="spinner-border spinner-border-sm me-2"/>
                    Chargement...
                </div>

                <div t-else="" class="cbm_content_container">

                    <!-- Filter chips -->
                    <div class="cbm_timeoff_filters" t-ref="filterBar"
                         t-on-mouseleave="() => this._snapIndicator()">
                        <!-- sliding highlight pill -->
                        <span class="cbm_filter_pill_indicator"/>
                        <button t-att-class="'cbm_filter_chip' + (state.filter === 'all' ? ' active' : '')"
                                t-on-click="() => this.setFilter('all')"
                                t-on-mouseenter="(e) => this.hoverPill(e.currentTarget)">
                            Tous
                            <span class="cbm_filter_count" t-esc="state.leaves.length"/>
                        </button>
                        <button t-att-class="'cbm_filter_chip' + (state.filter === 'pending' ? ' active' : '')"
                                t-on-click="() => this.setFilter('pending')"
                                t-on-mouseenter="(e) => this.hoverPill(e.currentTarget)">
                            En attente
                            <span class="cbm_filter_count"
                                  t-esc="state.leaves.filter(l => ['draft','confirm','validate1'].includes(l.state)).length"/>
                        </button>
                        <button t-att-class="'cbm_filter_chip' + (state.filter === 'validate' ? ' active' : '')"
                                t-on-click="() => this.setFilter('validate')"
                                t-on-mouseenter="(e) => this.hoverPill(e.currentTarget)">
                            Approuvés
                            <span class="cbm_filter_count"
                                  t-esc="state.leaves.filter(l => l.state === 'validate').length"/>
                        </button>
                        <button t-att-class="'cbm_filter_chip' + (state.filter === 'refuse' ? ' active' : '')"
                                t-on-click="() => this.setFilter('refuse')"
                                t-on-mouseenter="(e) => this.hoverPill(e.currentTarget)">
                            Refusés
                            <span class="cbm_filter_count"
                                  t-esc="state.leaves.filter(l => l.state === 'refuse').length"/>
                        </button>
                    </div>

                    <!-- Empty state -->
                    <div t-if="filteredLeaves.length === 0" class="cbm_timeoff_empty">
                        <span class="cbm_icon_calendar cbm_icon_3x"/>
                        <p>Aucune demande trouvée</p>
                    </div>

                    <!-- Leave list -->
                    <div t-else="" class="cbm_timeoff_requests_list">
                        <t t-foreach="filteredLeaves" t-as="leave" t-key="leave.id">
                            <div t-att-class="'cbm_timeoff_request_card ' + getStateClass(leave.state)">
                                <div class="cbm_request_card_main">

                                    <!-- Avatar -->
                                    <div class="cbm_request_avatar">
                                        <span t-esc="getInitials(leave.employee_name)"/>
                                    </div>

                                    <!-- Info -->
                                    <div class="cbm_request_card_info">
                                        <div class="cbm_request_employee"
                                             t-esc="toTitleCase(leave.employee_name)"/>
                                        <div class="cbm_request_meta">
                                            <span class="cbm_request_type" t-esc="leave.leave_type"/>
                                            <span class="cbm_request_sep">·</span>
                                            <span class="cbm_request_dates">
                                                <t t-esc="leave.date_from"/>
                                                <t t-if="leave.date_to &amp;&amp; leave.date_to !== leave.date_from">
                                                    → <t t-esc="leave.date_to"/>
                                                </t>
                                            </span>
                                            <span class="cbm_request_sep">·</span>
                                            <span class="cbm_request_days">
                                                <t t-esc="leave.number_of_days"/> j
                                            </span>
                                        </div>
                                        <div t-if="leave.name" class="cbm_request_reason">
                                            <span class="cbm_icon_chat me-1"/>
                                            <span t-esc="leave.name"/>
                                        </div>
                                    </div>

                                    <!-- Status badge -->
                                    <div class="cbm_request_card_status">
                                        <span t-att-class="getStateBadgeClass(leave.state)"
                                              t-esc="getStateLabel(leave.state)"/>
                                    </div>
                                </div>

                                <div class="cbm_request_card_actions">
                                    <!-- Print — pushed left via margin-right:auto in CSS -->
                                    <button class="cbm_btn_icon"
                                            t-on-click="() => this.printLeave(leave.id)"
                                            title="Imprimer le reçu PDF">
                                        <span class="cbm_icon_printer"/>
                                    </button>
                                    <!-- Approve -->
                                    <button t-if="canApprove(leave.state)"
                                            class="cbm_btn_success"
                                            t-att-disabled="state.actionInProgress === leave.id"
                                            t-on-click="() => this.approveLeave(leave.id)">
                                        <t t-if="state.actionInProgress === leave.id">
                                            <span class="spinner-border spinner-border-sm"/>
                                        </t>
                                        <t t-else="">
                                            <span class="cbm_icon_check"/>
                                        </t>
                                        Approuver
                                    </button>
                                    <!-- Refuse -->
                                    <button t-if="canRefuse(leave.state)"
                                            class="cbm_btn_danger"
                                            t-att-disabled="state.actionInProgress === leave.id"
                                            t-on-click="() => this.refuseLeave(leave.id)">
                                        <t t-if="state.actionInProgress === leave.id">
                                            <span class="spinner-border spinner-border-sm"/>
                                        </t>
                                        <t t-else="">
                                            <span class="cbm_icon_x"/>
                                        </t>
                                        Refuser
                                    </button>
                                </div>
                            </div>
                        </t>
                    </div>

                </div>
            </div>
        </div>
    </t>

</templates>