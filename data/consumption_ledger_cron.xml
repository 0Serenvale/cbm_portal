<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job to archive old consumption ledger entries (3 months) -->
        <record id="ir_cron_cleanup_consumption_ledger" model="ir.cron">
            <field name="name">Consumption Ledger: Archive Old Entries</field>
            <field name="model_id" ref="model_clinic_consumption_ledger"/>
            <field name="state">code</field>
            <field name="code">model.cleanup_old_entries(months=3)</field>
            <field name="interval_number">1</field>
            <field name="interval_type">weeks</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
            <field name="doall">False</field>
        </record>
    </data>
</odoo>
