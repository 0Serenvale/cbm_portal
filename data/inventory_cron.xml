<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- Cron Job: Quarterly Inventory Trigger -->
        <!-- Creates a draft session on Jan 1, Apr 1, Jul 1, Oct 1 -->
        <record id="inventory_cron_quarterly_trigger" model="ir.cron">
            <field name="name">Quarterly Inventory Trigger</field>
            <field name="model_id" ref="model_clinic_inventory"/>
            <field name="state">code</field>
            <field name="code">
model = env['clinic.inventory']
model.action_trigger_quarterly_inventory()
            </field>
            <field name="user_id" ref="base.user_admin"/>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall">False</field>
            <field name="nextcall">2026-04-01 00:15:00</field>
            <field name="active">True</field>
        </record>

    </data>
</odoo>
