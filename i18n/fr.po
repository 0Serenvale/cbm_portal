#. module: clinic_staff_portal
#: model:mail.template,body_html:clinic_staff_portal.mail_template_drh_escalation
msgid ""
"\n"
"<div style=\"font-family: 'Segoe UI', Arial, sans-serif; max-width: 650px; margin: 0 auto; color: #333;\">\n"
"    \n"
"    <!-- Professional Header -->\n"
"    <div style=\"background: linear-gradient(135deg, #1e3a5f, #2d5a87); padding: 25px 30px; border-radius: 8px 8px 0 0;\">\n"
"        <h2 style=\"color: white; margin: 0; font-weight: 400; letter-spacing: 0.5px;\">Communication Interne</h2>\n"
"        <p style=\"color: rgba(255,255,255,0.8); margin: 5px 0 0 0; font-size: 13px;\">Direction des Ressources Humaines</p>\n"
"    </div>\n"
"    \n"
"    <!-- Main Content -->\n"
"    <div style=\"background: #ffffff; padding: 30px; border-left: 1px solid #e0e0e0; border-right: 1px solid #e0e0e0;\">\n"
"        \n"
"        <p style=\"margin: 0 0 20px 0; font-size: 15px; line-height: 1.6;\">\n"
"            Madame, Monsieur,\n"
"        </p>\n"
"        \n"
"        <p style=\"margin: 0 0 20px 0; font-size: 15px; line-height: 1.6;\">\n"
"            Je me permets de porter à votre attention une situation qui nécessite votre intervention concernant \n"
"            <strong>${ctx.get('department_name', 'un département')}</strong>.\n"
"        </p>\n"
"        \n"
"        <!-- Key Metrics Box -->\n"
"        <div style=\"background: #f8f9fa; border-left: 4px solid #dc3545; padding: 20px; margin: 25px 0; border-radius: 0 4px 4px 0;\">\n"
"            <p style=\"margin: 0 0 10px 0; font-size: 14px; color: #6c757d;\">Situation actuelle :</p>\n"
"            <p style=\"margin: 0; font-size: 24px; font-weight: 600; color: #1e3a5f;\">\n"
"                ${ctx.get('picking_count', 0)} mouvement(s) en attente\n"
"            </p>\n"
"            <p style=\"margin: 10px 0 0 0; font-size: 14px; color: #6c757d;\">\n"
"                Délai maximum constaté : <strong style=\"color: #dc3545;\">${ctx.get('max_days', 0)} jours</strong>\n"
"            </p>\n"
"        </div>\n"
"        \n"
"        <p style=\"margin: 0 0 20px 0; font-size: 15px; line-height: 1.6;\">\n"
"            Cette accumulation de mouvements non validés représente un <strong>risque opérationnel</strong> \n"
"            pouvant affecter la continuité des services et l'exactitude de notre inventaire.\n"
"        </p>\n"
"        \n"
"        <p style=\"margin: 0 0 20px 0; font-size: 15px; line-height: 1.6;\">\n"
"            Je vous serais reconnaissant(e) de bien vouloir examiner cette situation avec \n"
"            le(s) responsable(s) concerné(s) afin d'identifier les causes de ce retard et de \n"
"            <strong>mettre en place les mesures correctives appropriées</strong>.\n"
"        </p>\n"
"        \n"
"        <!-- Diplomatic Note -->\n"
"        <div style=\"background: #fff8e1; border: 1px solid #ffc107; padding: 15px; border-radius: 4px; margin: 25px 0;\">\n"
"            <p style=\"margin: 0; font-size: 13px; color: #856404; line-height: 1.5;\">\n"
"                <strong>Note :</strong> Cette notification a un caractère strictement confidentiel. \n"
"                Elle vise à assurer le bon fonctionnement opérationnel de l'établissement et ne \n"
"                constitue en aucun cas un jugement sur la performance individuelle.\n"
"            </p>\n"
"        </div>\n"
"        \n"
"        <p style=\"margin: 0 0 5px 0; font-size: 15px; line-height: 1.6;\">\n"
"            Je reste à votre disposition pour tout échange complémentaire.\n"
"        </p>\n"
"        \n"
"        <p style=\"margin: 25px 0 0 0; font-size: 15px;\">\n"
"            Cordialement,\n"
"        </p>\n"
"        <p style=\"margin: 5px 0 0 0; font-size: 15px; font-weight: 600; color: #1e3a5f;\">\n"
"            ${ctx.get('sender_name', 'La Direction')}\n"
"        </p>\n"
"        \n"
"    </div>\n"
"    \n"
"    <!-- Footer -->\n"
"    <div style=\"background: #f5f5f5; padding: 15px 30px; border-radius: 0 0 8px 8px; border: 1px solid #e0e0e0; border-top: none;\">\n"
"        <p style=\"margin: 0; font-size: 11px; color: #888; text-align: center;\">\n"
"            CBM Portal • Communication confidentielle • ${ctx.get('send_date', '')}\n"
"        </p>\n"
"    </div>\n"
"    \n"
"</div>\n"
"        "
msgstr ""

